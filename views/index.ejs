<!-- hero Section -->
<div class="hero">
  <img src="/images/star1.svg" alt="" class="stars-bg star-1">
  <img src="/images/star1.svg" alt="" class="stars-bg star-2">
  <img src="/images/star1.svg" alt="" class="stars-bg star-3">
  <img src="/images/star1.svg" alt="" class="stars-bg star-4">

  <div class="hero-content">
    <p class="hero-eyebrow">Art Institute of Chicago Collection</p>
    <h1 class="hero-title">Discover Art<br /><em>by Color & Era</em></h1>
    <p class="hero-subtitle">Search thousands of public domain masterworks. Filter by color palette, time period, or
      artistic style.</p>

    <!-- search form -->
    <form action="/art/search" method="GET" class="hero-search">
      <input type="text" name="q" placeholder="Search by title, artist, style…" class="hero-input" autocomplete="off" />
      <button type="submit" class="hero-search-btn">Explore</button>
    </form>

    <!-- quick filter links -->
    <div class="hero-quick-links">
      <a href="/art/search?q=portrait" class="quick-link">
        <span class="ql-icon ql-portrait"></span>
        Portraits
      </a>
      <a href="/art/search?q=Landscape" class="quick-link">
        <span class="ql-icon" style="background:linear-gradient(135deg,#e63946,#457b9d,#2a9d8f)"></span>
        Landscape
      </a>
      <a href="/art/search?q=Still Life" class="quick-link">
        <span class="ql-icon ql-era"></span>
        Still Life
      </a>
    </div>
  </div>

  <!-- featured artwork -->
  <% if (featured && featured.imageUrl) { %>
    <div class="hero-featured">
      <a href="/art/detail/<%= featured.id %>" class="hero-img-link">
        <img src="<%= featured.imageUrl %>" alt="<%= featured.title %>" class="hero-img" />
        <div class="hero-img-caption">
          <span class="caption-title">
            <%= featured.title %>
          </span>
          <span class="caption-artist">
            <%= featured.artist_title || featured.artist_display %>
          </span>
        </div>
      </a>
    </div>
    <% } %>
</div>


<!-- browse by color section -->
<section class="mood-section">
  <h2 class="section-title">Browse by Color</h2>
  <div class="mood-grid">
    <a href="/art/search?colorHue=210" class="mood-card mood-calm">
      <div class="mood-swatch"></div>
      <span class="mood-label">Calm & Serene</span>
      <span class="mood-desc">Blues & Greens</span>
    </a>
    <a href="/art/search?colorHue=0" class="mood-card mood-energetic">
      <div class="mood-swatch"></div>
      <span class="mood-label">Bold & Energetic</span>
      <span class="mood-desc">Reds & Oranges</span>
    </a>
    <a href="/art/search?colorHue=50" class="mood-card mood-joyful">
      <div class="mood-swatch"></div>
      <span class="mood-label">Warm & Joyful</span>
      <span class="mood-desc">Yellows & Golds</span>
    </a>
    <a href="/art/search?colorHue=275" class="mood-card mood-mysterious">
      <div class="mood-swatch"></div>
      <span class="mood-label">Mysterious</span>
      <span class="mood-desc">Violets & Purples</span>
    </a>
  </div>
</section>

